# Token de tu Bot de Discord (Obtenido en Discord Developer Portal)
DISCORD_TOKEN=tu_token_aqui

# ID del canal donde la IA responderá automáticamente a todos los mensajes (Opcional)
# Si no se pone, la IA solo responderá cuando la menciones (@Bot)
AI_CHANNEL_ID=

# API Key de OpenRouter (Obtenida en https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-tu_clave_aqui

# Modelo de IA a usar (Qwen gratis recomendado)
AI_MODEL=qwen/qwen-2.5-7b-instruct

# Prompt del sistema (Personalidad de la IA)
AI_SYSTEM_PROMPT=Eres Nova, un asistente virtual útil y amigable en Discord. Responde de forma concisa y clara en español.
